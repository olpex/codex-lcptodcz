APP_NAME=СУПТЦ
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

DATABASE_URL=postgresql+psycopg2://suptc:suptc@postgres:5432/suptc
REDIS_URL=redis://redis:6379/0

DATA_ENCRYPTION_KEY=replace-with-fernet-key
FILE_STORAGE_PATH=/data/documents

IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=inbox@example.com
IMAP_PASSWORD=change-me
IMAP_MAILBOX=INBOX
IMAP_BRANCH_ID=main
IMAP_POLL_INTERVAL_SECONDS=300
IMAP_ALLOWED_SENDERS=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change-me

OCR_LANGUAGE=ukr+eng
TESSERACT_CMD=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_OCR_ENABLED=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin123!
INITIAL_ADMIN_FULL_NAME=Системний адміністратор
ADMIN_PASSWORD_RESET_TOKEN=change-this-reset-token

VITE_API_URL=http://localhost:8000/api/v1
